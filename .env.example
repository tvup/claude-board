APP_NAME="Claude Board"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8080
VITE_PORT=5173

APP_LOCALE=en  # en|da
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=file

CLAUDE_BILLING_MODEL=subscription  # subscription|api

# CLAUDE_USAGE_API_URL=https://ai-apis-usage.christianogfars.online/api/claude/status

VITE_APP_NAME="${APP_NAME}"
